NODE_ENV=development
PORT=3000

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

RESEND_API_KEY=re_...
# Must be a verified sender domain in Resend
RESEND_FROM_EMAIL="ClientPulse <noreply@clientpulse.dev>"

# Must be >= 32 chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Must be >= 32 chars. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# Dev: http://localhost:3000  |  Prod: https://your-render-app.onrender.com
APP_BASE_URL=http://localhost:3000

# Comma-separated list of allowed frontend origins
# Dev: http://localhost:5000  |  Prod: https://clientpulse.web.app
ALLOWED_ORIGINS=http://localhost:5000

# Frontend base URL — used to construct portal links in notification emails
# Dev: http://localhost:5000  |  Prod: https://clientpulse.web.app
FRONTEND_BASE_URL=http://localhost:5000
